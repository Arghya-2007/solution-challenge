# JWT Secret used to sign and verify authentication tokens
JWT_SECRET=your_super_secret_jwt_key_here

# Name of the Google Cloud Storage bucket
GCS_BUCKET_NAME=your-gcs-bucket-name

# The exact origin allowed for CORS (e.g., https://yourfrontend.com)
ALLOWED_ORIGIN=http://localhost:3000

# Maximum file size allowed for uploads (in bytes). Default is 524288000 (500MB)
MAX_FILE_SIZE_BYTES=524288000

# Port for the NestJS server to listen on
PORT=3000
